# Copy this file to `.env` and fill in your key, then run: npm run gen:assets
#
# Get an API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# API base URL — override to use a proxy / self-hosted gateway.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Image-generation model (must support image output).
# Default is Google Gemini 2.5 Flash Image ("Nano Banana").
# Alternatives: bytedance-seed/seedream-4.5, openai/gpt-image-1
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# Optional: shown to OpenRouter for attribution (any values are fine)
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_TITLE=Gingko Idle RPG
